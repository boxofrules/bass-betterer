<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements for the signed/notarized macOS build.

  disable-library-validation lets a DAW host (which has its own Team ID) load our
  plug-in bundle, and lets the bundle load its embedded JUCE code, under the hardened
  runtime. Without it, hosts signed by a different team refuse to load the plug-in.
  The Standalone's microphone access is governed by TCC + the NSMicrophoneUsageDescription
  string set in CMakeLists (MICROPHONE_PERMISSION_*), not by an entitlement here.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
